# Copy this file to .env for local development.
# For Render, add these values in the Render dashboard instead of committing a real .env.
# Supabase Postgres (recommended): set a single DATABASE_URL
# Example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ALERT_EMAIL_TO=

# Optional explicit fields (used if DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=postgres
DB_SSLMODE=require

JWT_SECRET_KEY=replace-with-a-secure-secret
FLASK_SECRET_KEY=replace-with-a-flask-secret
MIN_PASSWORD_LENGTH=8
ALLOW_MODEL_DOWNLOADS=false
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
PORT=10000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
